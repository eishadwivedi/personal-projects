import random
def play():
  user=input("Whats your choice? 'r' for rock, 'p' for paper and 's' for scissor \n").lower()
  comp= random.choice(['r','p','s'])

  if user==comp:
    return "It\'s a TIE"
  
  if is_win(user, comp):
    return "Woohoo! You have won!!"
  
  return "OHno! You have lost. Try again.."


def is_win(user, comp):
  # condition for winning; 
  if ((user=='r' and comp=='s')or (user=='p' and comp=='r') or (user=='s' and comp=='p')):
    return True
      
play()
